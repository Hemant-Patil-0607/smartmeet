# App
APP_NAME=SmartMeet
DEBUG=false

# Auth - REQUIRED (min 32 chars, use: openssl rand -hex 32)
SECRET_KEY=your-super-secret-key-at-least-32-characters-long-change-this
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
POSTGRES_USER=smartmeet
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=smartmeet
DATABASE_URL=postgresql://smartmeet:changeme_in_production@localhost:5432/smartmeet

# Redis
REDIS_PASSWORD=changeme_in_production
REDIS_URL=redis://:changeme_in_production@localhost:6379/0

# Storage (Supabase S3-compatible)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_BUCKET_NAME=smartmeet-storage
AWS_REGION=us-east-1
S3_ENDPOINT_URL=https://your-project.supabase.co/storage/v1/s3

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_DAY=1000

# File Upload
MAX_UPLOAD_SIZE_MB=500
